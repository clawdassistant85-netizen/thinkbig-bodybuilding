---
import { SEO } from "astro-seo";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title = "Think BIG Bodybuilding Media",
  description = "The bodybuilding podcast network that goes there. Four hardcore shows — Blood Sweat & Gear, Drugs N Stuff, It's Just Bodybuilding, and Muscle Minds — hosted by elite coaches and IFBB Pros.",
  image = "/social-card.png",
  canonicalUrl,
} = Astro.props;

const canonical =
  canonicalUrl ||
  new URL(Astro.url.pathname, Astro.site ?? "https://thinkbigbodybuilding.com")
    .toString();
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title,
          type: "website",
          image,
          url: canonical,
        },
        optional: {
          description,
          siteName: "Think BIG Bodybuilding Media",
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@ThinkBigBB",
        title,
        description,
        image,
      }}
    />
  </head>
  <body
    class="bg-[#0a0a0a] text-neutral-100 min-h-screen flex flex-col font-sans antialiased"
  >
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
