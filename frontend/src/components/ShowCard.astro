---
export interface Props {
  show: {
    id: string;
    name: string;
    shortName: string;
    slug: string;
    color: string;
    tagline: string;
    description: string;
    hosts: string[];
    episodeCount: string;
    spotifyUrl: string;
    appleUrl: string;
    topics: string[];
    icon: string;
  };
  index?: number;
}

const { show } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}${show.slug}`} class="show-card" style={`--c:${show.color};`}>
  <div class="sc-stripe" aria-hidden="true"></div>

  <div class="sc-body">
    <!-- Badge floated to top-right -->
    <span class="sc-badge" style={`color:${show.color}; border-color:${show.color}44; background:${show.color}12;`}>
      {show.episodeCount}&thinsp;eps
    </span>

    <h3 class="sc-name">{show.name}</h3>
    <p class="sc-tagline" style={`color:${show.color};`}>{show.tagline}</p>
    <p class="sc-desc">{show.description}</p>

    <div class="sc-topics">
      {show.topics.slice(0, 4).map((t) => (
        <span class="sc-topic" style={`border-color:${show.color}30; color:${show.color}cc;`}>{t}</span>
      ))}
    </div>

    <div class="sc-foot">
      <p class="sc-hosts">{show.hosts.join(' · ')}</p>
      <div class="sc-actions" onclick="event.preventDefault(); event.stopPropagation();">
        <a href={show.spotifyUrl} target="_blank" rel="noopener noreferrer" class="sc-icon-btn" title="Spotify">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
        </a>
        <a href={show.appleUrl} target="_blank" rel="noopener noreferrer" class="sc-icon-btn" title="Apple Podcasts">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 4.1c3.2 0 5.8 2.6 5.8 5.8 0 2.2-1.2 4.1-3 5.1v1c0 .8-.6 1.5-1.4 1.6l-.1.1c-.4 1-1.4 1.7-2.6 1.7-1.3 0-2.3-.8-2.7-1.9-.7-.2-1.2-.9-1.2-1.6v-.9c-1.8-1-3-2.9-3-5.1 0-3.2 2.6-5.8 5.8-5.8h2.4zM12 6c-2.2 0-4 1.8-4 4 0 1.5.9 2.9 2.2 3.5v-1.1c0-.5.4-.9.9-.9h1.7c.5 0 .9.4.9.9v1.1c1.3-.6 2.2-2 2.2-3.5 0-2.2-1.8-4-3.9-4z"/></svg>
        </a>
        <span class="sc-listen-btn" style={`background:${show.color};`}>
          Listen
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </div>
    </div>
  </div>

  <div class="sc-glow" style={`background:linear-gradient(90deg,${show.color}18 0%,transparent 55%);`} aria-hidden="true"></div>
</a>

<style>
  .show-card {
    display: flex;
    background: #0f0f0f;
    border-bottom: 1px solid #1e1e1e;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: background 180ms;
  }
  .show-card:hover { background: #141414; }

  .sc-stripe {
    flex-shrink: 0;
    width: 6px;
    background: var(--c);
  }
  @media (min-width: 640px) { .sc-stripe { width: 8px; } }

  /* block layout — no flexbox, stacking is guaranteed */
  .sc-body {
    flex: 1;
    min-width: 0;
    display: block;
    padding: 2rem 2rem 1.5rem;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px) { .sc-body { padding: 2.25rem 2.5rem 1.75rem; } }

  .sc-badge {
    float: right;
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.2rem 0.55rem;
    border: 1px solid;
    border-radius: 3px;
    white-space: nowrap;
    margin: 0.3rem 0 0 1rem;
    position: relative;
    top: 0.1rem;
  }

  .sc-name {
    display: block;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 0.35rem;
    transition: color 180ms;
  }
  .show-card:hover .sc-name { color: var(--c); }

  .sc-tagline {
    display: block;
    font-size: 0.63rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin: 0 0 1rem;
  }

  .sc-desc {
    display: block;
    font-size: 0.875rem;
    color: #5a5a5a;
    line-height: 1.65;
    margin: 0 0 1.25rem;
    max-width: 72ch;
  }

  .sc-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.85rem;
    border-top: 1px solid #1e1e1e;
    clear: both;
  }

  .sc-hosts {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #333;
    margin: 0;
  }

  .sc-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .sc-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    border-radius: 3px;
    border: 1px solid #1e1e1e;
    color: #333;
    text-decoration: none;
    transition: color 150ms, border-color 150ms;
  }
  .sc-icon-btn:hover { color: #888; border-color: #333; }

  .sc-listen-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.75rem;
    border-radius: 3px;
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #fff;
    pointer-events: none;
    white-space: nowrap;
  }

  .sc-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 1.1rem;
  }
  .sc-topic {
    font-size: 0.56rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    padding: 0.18rem 0.5rem;
    border: 1px solid;
    border-radius: 2px;
    background: transparent;
  }

  .sc-glow {
    position: absolute; inset: 0;
    opacity: 0; pointer-events: none;
    transition: opacity 200ms;
  }
  .show-card:hover .sc-glow { opacity: 1; }
</style>
