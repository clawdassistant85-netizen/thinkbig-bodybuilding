---
import { shows } from "../data/shows.js";
import { social } from "../data/social.js";
const base = import.meta.env.BASE_URL;
---

<footer class="bg-[#0a0a0a] border-t border-[#222] mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-2">
        <a href={base} class="flex items-center gap-2 font-black text-2xl">
          <span class="text-neutral-100">Think</span>
          <span class="text-[#dc2626]">BIG</span>
        </a>
        <p class="mt-3 text-sm text-neutral-400 max-w-sm leading-relaxed">
          The bodybuilding podcast network that goes there. Four shows, 1,000+
          episodes, and the most trusted voices in hardcore bodybuilding.
        </p>
        <div class="flex items-center gap-3 mt-5">
          <a
            href={social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="p-2 text-neutral-400 hover:text-[#dc2626] transition-colors border border-[#222] rounded"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
                d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
                x1="17.5"
                y1="6.5"
                x2="17.51"
                y2="6.5"></line></svg
            >
          </a>
          <a
            href={social.youtube}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
            class="p-2 text-neutral-400 hover:text-[#dc2626] transition-colors border border-[#222] rounded"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M23.498 6.186a2.99 2.99 0 0 0-2.107-2.117C19.455 3.55 12 3.55 12 3.55s-7.455 0-9.391.519A2.99 2.99 0 0 0 .502 6.186C0 8.132 0 12 0 12s0 3.868.502 5.814a2.99 2.99 0 0 0 2.107 2.117c1.936.519 9.391.519 9.391.519s7.455 0 9.391-.519a2.99 2.99 0 0 0 2.107-2.117C24 15.868 24 12 24 12s0-3.868-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"
              ></path>
            </svg>
          </a>
          <a
            href={social.twitter}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Twitter"
            class="p-2 text-neutral-400 hover:text-[#dc2626] transition-colors border border-[#222] rounded"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Shows -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest text-[#dc2626] mb-4"
        >
          Shows
        </h3>
        <ul class="space-y-2 text-sm">
          {
            shows.map((show) => (
              <li>
                <a
                  href={`${base}${show.slug}`}
                  class="text-neutral-400 hover:text-white transition-colors"
                >
                  {show.name}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={`${base}about`}
              class="text-neutral-400 hover:text-white transition-colors"
              >About</a
            >
          </li>
          <li>
            <a
              href={`${base}partners`}
              class="text-neutral-400 hover:text-white transition-colors"
              >Partners</a
            >
          </li>
        </ul>
      </div>

      <!-- Listen -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest text-[#dc2626] mb-4"
        >
          Listen
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href={social.spotify}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-400 hover:text-white transition-colors"
              >Spotify</a
            >
          </li>
          <li>
            <a
              href={social.apple}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-400 hover:text-white transition-colors"
              >Apple Podcasts</a
            >
          </li>
          <li>
            <a
              href={social.youtube}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-400 hover:text-white transition-colors"
              >YouTube</a
            >
          </li>
          <li>
            <a
              href={social.soundcloud}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-400 hover:text-white transition-colors"
              >SoundCloud</a
            >
          </li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest text-[#dc2626] mb-4"
        >
          Support
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href={social.patreon}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-400 hover:text-white transition-colors"
              >Patreon</a
            >
          </li>
          <li>
            <a
              href={social.merch}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-400 hover:text-white transition-colors"
              >Merch</a
            >
          </li>
          <li>
            <a
              href={social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-400 hover:text-white transition-colors"
              >Facebook Group</a
            >
          </li>
          <li>
            <a
              href="mailto:mcnallydiets@gmail.com"
              class="text-neutral-400 hover:text-white transition-colors"
              >Contact</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 pt-6 border-t border-[#222] flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-neutral-500"
    >
      <p>
        &copy; {new Date().getFullYear()} Think BIG Bodybuilding Media. All rights
        reserved.
      </p>
      <p>Built for serious competitors and coaches.</p>
    </div>
  </div>
</footer>
