---
import YouTubeEmbed from "./YouTubeEmbed.astro";
import SponsorBar from "./SponsorBar.astro";
import HostCard from "./HostCard.astro";
import { hosts as allHosts } from "../data/hosts.js";
import { social } from "../data/social.js";

export interface Props {
  show: {
    id: string;
    name: string;
    shortName: string;
    slug: string;
    color: string;
    colorName: string;
    tagline: string;
    description: string;
    hosts: string[];
    episodeCount: string;
    youtubeChannel: string;
    youtubePlaylist: string;
    spotifyUrl: string;
    appleUrl: string;
    sampleVideoId: string;
    rssKeyword: string;
    topics: string[];
    icon: string;
  };
  heroClass: string;
}

const { show, heroClass } = Astro.props;

const showHosts = allHosts.filter((h) => show.hosts.includes(h.name));

interface Episode {
  title: string;
  link: string;
  pubDate: string;
  duration: string;
  epNum: string;
  youtubeId: string;
}

function decodeEntities(s: string) {
  return s
    .replace(/&amp;/g, "&")
    .replace(/&quot;/g, '"')
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&#39;|&apos;/g, "'")
    .trim();
}
function fmtDate(s: string) {
  const d = new Date(s);
  return isNaN(d.getTime())
    ? ""
    : d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

let recentEpisodes: Episode[] = [];

try {
  const [scRes, ytRes] = await Promise.allSettled([
    fetch(
      "https://feeds.soundcloud.com/users/soundcloud:users:690728360/sounds.rss",
      { signal: AbortSignal.timeout(8000) }
    ),
    fetch(
      "https://www.youtube.com/feeds/videos.xml?channel_id=UCrZIZSnyfieo3cX2swc36iw",
      { signal: AbortSignal.timeout(5000) }
    ),
  ]);

  // Parse YouTube videos for this show
  let ytVideos: { id: string; title: string }[] = [];
  if (ytRes.status === "fulfilled" && ytRes.value.ok) {
    const ytXml = await ytRes.value.text();
    const entries = [...ytXml.matchAll(/<entry>([\s\S]*?)<\/entry>/g)].map((m) => m[1]);
    ytVideos = entries
      .map((e) => ({
        id: e.match(/<yt:videoId>(.*?)<\/yt:videoId>/)?.[1]?.trim() ?? "",
        title: decodeEntities(e.match(/<title>([\s\S]*?)<\/title>/)?.[1] ?? ""),
      }))
      .filter((v) => v.id && v.title.toLowerCase().includes(show.rssKeyword.toLowerCase()));
  }

  // Parse SoundCloud episodes and match to YouTube
  if (scRes.status === "fulfilled" && scRes.value.ok) {
    const xml = await scRes.value.text();
    const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)].map((m) => m[1]);

    const scEps = items
      .map((item) => {
        const rawTitle = decodeEntities(
          item.match(/<title>(?:<!\[CDATA\[)?([\s\S]*?)(?:\]\]>)?<\/title>/)?.[1] ?? ""
        );
        const link = item.match(/<link>(.*?)<\/link>/)?.[1]?.trim() ?? "";
        const pubDate = fmtDate(item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? "");
        const duration = item.match(/<itunes:duration>(.*?)<\/itunes:duration>/)?.[1]?.trim() ?? "";
        const numMatch = rawTitle.match(/\b(\d{2,4})\b/);
        const epNum = numMatch ? numMatch[1] : "";
        return { title: rawTitle, link, pubDate, duration, epNum };
      })
      .filter((ep) => ep.title.toLowerCase().includes(show.rssKeyword.toLowerCase()))
      .slice(0, 10);

    recentEpisodes = scEps.map((ep) => {
      const ytMatch = ep.epNum ? ytVideos.find((v) => v.title.includes(ep.epNum)) : undefined;
      return { ...ep, youtubeId: ytMatch?.id ?? "" };
    });
  }
} catch {
  // RSS unavailable at build time — episodes section hidden
}
---

<!-- HERO -->
<section class={`relative overflow-hidden ${heroClass}`}>
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 md:pt-28 md:pb-20"
  >
    <div class="max-w-4xl">
      <div class="flex items-center gap-3">
        <span class="text-4xl">{show.icon}</span>
        <span
          class="tb-label"
          style={`color:${show.color};`}
        >
          Think BIG Network · {show.episodeCount} Episodes
        </span>
      </div>
      <h1
        class="mt-5 text-4xl sm:text-5xl md:text-7xl font-black tracking-tight leading-[1.02] text-white"
      >
        {show.name}
      </h1>
      <p
        class="mt-4 text-xl md:text-2xl font-bold italic"
        style={`color:${show.color};`}
      >
        "{show.tagline}"
      </p>
      <p
        class="mt-6 text-base md:text-lg text-neutral-400 max-w-3xl leading-relaxed"
      >
        {show.description}
      </p>

      <!-- Hosts -->
      <div class="mt-6 flex flex-wrap gap-2">
        {
          show.hosts.map((h) => (
            <span
              class="text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full border"
              style={`color:${show.color}; border-color:${show.color}55; background:${show.color}15;`}
            >
              {h}
            </span>
          ))
        }
      </div>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={show.spotifyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 rounded text-sm font-bold uppercase tracking-widest text-white transition-transform hover:-translate-y-0.5"
          style={`background:${show.color};`}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
            ></path>
          </svg>
          Listen on Spotify
        </a>
        <a
          href={show.appleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 rounded bg-transparent border border-[#333] text-white text-sm font-bold uppercase tracking-widest hover:border-white transition-colors"
        >
          Apple Podcasts
        </a>
        <a
          href={show.youtubeChannel}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 rounded bg-transparent border border-[#333] text-white text-sm font-bold uppercase tracking-widest hover:border-[#dc2626] hover:text-[#dc2626] transition-colors"
        >
          YouTube
        </a>
      </div>
    </div>
  </div>
</section>

<!-- TOPICS -->
<section class="py-16 border-b border-[#222]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <span class="tb-label" style={`color:${show.color};`}>What We Cover</span>
      <h2 class="mt-2 text-2xl md:text-4xl font-black text-white tracking-tight">
        Topics On The Show
      </h2>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      {
        show.topics.map((topic) => (
          <span
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#141414] border text-sm font-semibold text-neutral-200"
            style={`border-color:${show.color}33;`}
          >
            <span
              class="w-1.5 h-1.5 rounded-full"
              style={`background:${show.color};`}
            />
            {topic}
          </span>
        ))
      }
    </div>
  </div>
</section>

<!-- FEATURED EPISODE (compact) -->
<section class="py-10 bg-[#0c0c0c] border-b border-[#222]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-5 gap-4 flex-wrap">
      <div>
        <span class="tb-label" style={`color:${show.color};`}>Featured</span>
        <h2 class="mt-1 text-lg font-black text-white tracking-tight">
          Latest Episode
        </h2>
      </div>
      <a
        href={show.youtubeChannel}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest transition-colors"
        style={`color:${show.color};`}
      >
        Full Playlist
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
    <div style="max-width:22rem;">
      <YouTubeEmbed
        videoId={show.sampleVideoId}
        title={`${show.name} — Latest Episode`}
      />
    </div>
  </div>
</section>

<!-- RECENT EPISODES -->
{recentEpisodes.length > 0 && (
  <section class="py-16 md:py-20 border-b border-[#222]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div>
          <span class="tb-label" style={`color:${show.color};`}>Episodes</span>
          <h2 class="mt-2 text-2xl md:text-4xl font-black text-white tracking-tight">
            Recent Episodes
          </h2>
        </div>
        <a
          href={show.youtubeChannel}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-bold uppercase tracking-widest transition-colors"
          style={`color:${show.color};`}
        >
          All Episodes →
        </a>
      </div>

      <div class="ep-list">
        {recentEpisodes.map((ep) => (
          <div class="ep-row" style={`--c:${show.color};`}>
            {/* Thumbnail — links to YouTube */}
            {ep.youtubeId ? (
              <a
                href={`https://www.youtube.com/watch?v=${ep.youtubeId}`}
                target="_blank"
                rel="noopener noreferrer"
                class="ep-thumb"
                aria-label={`Watch on YouTube`}
              >
                <img
                  src={`https://i.ytimg.com/vi/${ep.youtubeId}/mqdefault.jpg`}
                  alt=""
                  loading="lazy"
                  class="ep-thumb-img"
                />
                <span class="ep-yt-badge" aria-hidden="true">
                  <svg width="28" height="20" viewBox="0 0 68 48" fill="none">
                    <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79 0 34 0 34 0S12.21 0 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C0 13.05 0 24 0 24s0 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 48 34 48 34 48s21.79 0 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C68 34.95 68 24 68 24s0-10.95-1.48-16.26z" fill="#FF0000"/>
                    <path d="M45 24 27 14v20l18-10z" fill="white"/>
                  </svg>
                </span>
              </a>
            ) : (
              <div class="ep-thumb ep-thumb-empty" style={`background:${show.color}12;`} aria-hidden="true">
                <span class="ep-thumb-icon">{show.icon}</span>
              </div>
            )}

            {/* Info — links to SoundCloud episode */}
            <a
              href={ep.link}
              target="_blank"
              rel="noopener noreferrer"
              class="ep-info"
            >
              <span class="ep-title">{ep.title}</span>
              <span class="ep-meta">
                {ep.epNum && <span class="ep-num">#{ep.epNum}</span>}
                {ep.duration && <span class="ep-dur">{ep.duration}</span>}
                {ep.pubDate && <span class="ep-date">{ep.pubDate}</span>}
              </span>
            </a>

            <span class="ep-arrow" aria-hidden="true">→</span>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- HOSTS -->
{
  showHosts.length > 0 && (
    <section class="py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-10">
          <span class="tb-label" style={`color:${show.color};`}>
            Your Hosts
          </span>
          <h2 class="mt-2 text-2xl md:text-4xl font-black text-white tracking-tight">
            Who You're Listening To
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {showHosts.map((h) => (
            <HostCard
              id={h.id}
              name={h.name}
              role={h.role}
              shows={h.shows}
              bio={h.bio}
              accent={show.color}
            />
          ))}
        </div>
      </div>
    </section>
  )
}

<!-- SPONSORS -->
<SponsorBar />

<!-- PATREON CTA -->
<section class="py-20 md:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="relative rounded-2xl overflow-hidden border border-[#222] p-8 md:p-14 text-center"
      style={`background: radial-gradient(ellipse at center, ${show.color}22, #0a0a0a 70%);`}
    >
      <span class="tb-label" style={`color:${show.color};`}>Go Deeper</span>
      <h2
        class="mt-3 text-3xl md:text-5xl font-black text-white tracking-tight"
      >
        Join The Patreon
      </h2>
      <p class="mt-4 text-neutral-400 max-w-2xl mx-auto">
        Exclusive episodes, early access, direct Q&A with the hosts, and more.
        Support the network and get closer to the content.
      </p>
      <a
        href={social.patreon}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 mt-8 px-6 py-3 rounded text-sm font-bold uppercase tracking-widest text-white transition-transform hover:-translate-y-0.5"
        style={`background:${show.color};`}
      >
        Become A Patron
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12 5 19 12 12 19"></polyline></svg
        >
      </a>
    </div>
  </div>
</section>

<style>
  /* Episode list */
  .ep-list {
    display: flex;
    flex-direction: column;
    border: 1px solid #1e1e1e;
    border-radius: 6px;
    overflow: hidden;
  }

  .ep-row {
    display: grid;
    grid-template-columns: 9rem 1fr 1.5rem;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #1a1a1a;
    background: #111;
    transition: background 150ms;
  }
  .ep-row:last-child { border-bottom: none; }
  .ep-row:hover { background: #161616; }

  /* Thumbnail */
  .ep-thumb {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 3px;
    overflow: hidden;
    background: #1a1a1a;
    flex-shrink: 0;
    text-decoration: none;
  }
  .ep-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 150ms;
  }
  .ep-thumb:hover .ep-thumb-img { opacity: 0.7; }

  .ep-yt-badge {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.85;
    transition: opacity 150ms;
  }
  .ep-thumb:hover .ep-yt-badge { opacity: 1; }

  .ep-thumb-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed #252525;
  }
  .ep-thumb-icon { font-size: 1.25rem; opacity: 0.4; }

  /* Info link */
  .ep-info {
    min-width: 0;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .ep-title {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ccc;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 150ms;
  }
  .ep-row:hover .ep-title { color: var(--c); }

  .ep-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .ep-num {
    font-size: 0.6rem;
    font-weight: 700;
    color: #444;
    letter-spacing: 0.04em;
  }
  .ep-dur {
    font-size: 0.6rem;
    font-weight: 600;
    color: #555;
    font-variant-numeric: tabular-nums;
  }
  .ep-date {
    font-size: 0.58rem;
    color: #3a3a3a;
    white-space: nowrap;
  }

  /* Arrow */
  .ep-arrow {
    font-size: 0.8rem;
    color: #2a2a2a;
    transition: color 150ms;
    text-align: center;
    flex-shrink: 0;
  }
  .ep-row:hover .ep-arrow { color: var(--c); }

  @media (max-width: 500px) {
    .ep-row {
      grid-template-columns: 6.5rem 1fr 1.25rem;
      gap: 0.6rem;
      padding: 0.5rem 0.75rem;
    }
  }
</style>
