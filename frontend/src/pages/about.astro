---
import Layout from "../layouts/Layout.astro";
import HostCard from "../components/HostCard.astro";
import SponsorBar from "../components/SponsorBar.astro";
import { hosts } from "../data/hosts.js";
import { shows } from "../data/shows.js";
import { social } from "../data/social.js";

const title = "About — Think BIG Bodybuilding Media";
const description =
  "The story behind Think BIG Bodybuilding Media — four shows, one network, built for serious competitors and coaches.";

const hostAccent = {
  BSG: "#dc2626",
  DNS: "#d97706",
  IJB: "#7c3aed",
  MM: "#0891b2",
};
function accentFor(showCodes) {
  if (!showCodes || !showCodes.length) return "#dc2626";
  return hostAccent[showCodes[0]] ?? "#dc2626";
}
---

<Layout title={title} description={description}>
  <!-- HERO -->
  <section class="relative overflow-hidden tb-hero-glow">
    <div
      class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 md:pt-28 md:pb-20"
    >
      <span class="tb-label text-[#dc2626]">About The Network</span>
      <h1
        class="mt-4 text-4xl sm:text-5xl md:text-7xl font-black tracking-tight leading-[1.02] text-white"
      >
        Built For Serious <span class="text-[#dc2626]">Lifters.</span>
      </h1>
      <p class="mt-6 text-base md:text-xl text-neutral-400 max-w-3xl leading-relaxed">
        Think BIG Bodybuilding Media is a four-show podcast network built from
        the ground up for competitive bodybuilders, coaches, and serious
        enhanced lifters. We don't talk about abs and morning smoothies — we
        talk about contest prep, PEDs, training science, and the reality of
        life on stage.
      </p>
    </div>
  </section>

  <!-- MISSION -->
  <section class="py-16 md:py-20 border-b border-[#222]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12">
      <div>
        <span class="tb-label text-[#dc2626]">Our Mission</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-black text-white tracking-tight">
          Real Answers. No Filter.
        </h2>
      </div>
      <div class="space-y-4 text-neutral-300 leading-relaxed">
        <p>
          The bodybuilding community was drowning in surface-level content —
          influencers selling programs, unqualified voices spreading
          misinformation, and mainstream media too afraid to talk about what
          actually happens behind the scenes of elite-level bodybuilding.
        </p>
        <p>
          Think BIG exists because serious people deserved a serious network.
          Every show is hosted by somebody with skin in the game: IFBB Pros who
          compete at the highest levels, prep coaches with decades of
          experience, a PhD exercise physiologist, and a harm-reduction
          specialist. No outsiders. No fluff. No filter.
        </p>
        <p>
          Over 1,000 episodes later, we're still doing the same thing we
          started with — answering your questions with real knowledge from real
          practitioners.
        </p>
      </div>
    </div>
  </section>

  <!-- STATS / SHOWS ROUND-UP -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <span class="tb-label text-[#dc2626]">The Network</span>
        <h2 class="mt-2 text-3xl md:text-5xl font-black text-white tracking-tight">
          Four Shows At A Glance
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {
          shows.map((show) => (
            <a
              href={`${import.meta.env.BASE_URL}${show.slug}`}
              class="tb-card rounded-lg p-6 border-l-4 flex items-start gap-4 group"
              style={`border-left-color:${show.color};`}
            >
              <span class="text-3xl">{show.icon}</span>
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-black text-white group-hover:underline">
                  {show.name}
                </h3>
                <p class="tb-label mt-1" style={`color:${show.color};`}>
                  {show.tagline}
                </p>
                <p class="mt-3 text-sm text-neutral-400 leading-relaxed">
                  {show.hosts.join(" · ")}
                </p>
              </div>
              <span
                class="shrink-0 text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded border"
                style={`color:${show.color}; border-color:${show.color}55; background:${show.color}11;`}
              >
                {show.episodeCount}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="py-16 md:py-20 bg-[#0c0c0c] border-y border-[#222]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="tb-label text-[#d97706]">Our Story</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-black text-white tracking-tight">
        From Advices Radio To Think BIG.
      </h2>
      <div class="mt-8 space-y-6 text-neutral-300 leading-relaxed text-lg">
        <p>
          The network grew out of Advices Radio — one of the earliest
          bodybuilding Q&A shows on the internet. What started as one show
          answering listener questions evolved, over a decade, into a full
          four-show network covering every angle of competitive bodybuilding.
        </p>
        <p>
          Blood Sweat & Gear came first — the flagship prep and PED show.
          Drugs N Stuff expanded the harm-reduction conversation with Dave
          Crosland's encyclopedic knowledge. It's Just Bodybuilding brought in
          IFBB Pros Big Ron Partlow and Dusty Hanshaw for the industry and
          personality angle. Muscle Minds closed the loop with Dr. Scott
          Stevenson's PhD-level science.
        </p>
        <p>
          Today, Think BIG is one of the most respected independent networks
          in the sport — hundreds of thousands of listeners, a Top 1% podcast
          ranking, and a loyal community of serious lifters who want the real
          answer, not the safe one.
        </p>
      </div>
    </div>
  </section>

  <!-- FULL TEAM -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <span class="tb-label text-[#dc2626]">The Full Team</span>
        <h2 class="mt-2 text-3xl md:text-5xl font-black text-white tracking-tight">
          Every Host. Every Show.
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          hosts.map((h) => (
            <HostCard
              id={h.id}
              name={h.name}
              role={h.role}
              shows={h.shows}
              bio={h.bio}
              accent={accentFor(h.shows)}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- SPONSORS -->
  <SponsorBar />

  <!-- CONTACT -->
  <section class="py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-2xl border border-[#222] p-8 md:p-14"
        style="background: radial-gradient(ellipse at top left, rgba(220,38,38,0.15), #0a0a0a 60%);"
      >
        <span class="tb-label text-[#dc2626]">Get In Touch</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-black text-white tracking-tight">
          Work With Us.
        </h2>
        <p class="mt-4 text-neutral-400 max-w-2xl">
          Coaching inquiries, guest pitches, sponsorship, or just a great
          listener question — all of it goes through Scott.
        </p>
        <div class="mt-8 grid sm:grid-cols-2 gap-4">
          <a
            href="mailto:mcnallydiets@gmail.com"
            class="tb-card rounded-lg p-5 flex items-center gap-4 hover:border-[#dc2626] transition-colors"
          >
            <div class="w-10 h-10 rounded bg-[#dc2626]/15 border border-[#dc2626]/30 flex items-center justify-center">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#dc2626"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg
              >
            </div>
            <div>
              <p class="tb-label text-[#dc2626]">Email</p>
              <p class="text-white font-bold">mcnallydiets@gmail.com</p>
            </div>
          </a>
          <a
            href={social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="tb-card rounded-lg p-5 flex items-center gap-4 hover:border-[#dc2626] transition-colors"
          >
            <div class="w-10 h-10 rounded bg-[#dc2626]/15 border border-[#dc2626]/30 flex items-center justify-center">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#dc2626"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg
              >
            </div>
            <div>
              <p class="tb-label text-[#dc2626]">Instagram</p>
              <p class="text-white font-bold">@scottmcnally1</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
