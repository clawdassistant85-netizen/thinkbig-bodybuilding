---
import Layout from "../../layouts/Layout.astro";
import { hosts } from "../../data/hosts.js";
import { shows } from "../../data/shows.js";

export function getStaticPaths() {
  return hosts.map((host) => ({
    params: { slug: host.slug },
    props: { host },
  }));
}

const { host } = Astro.props;
const base = import.meta.env.BASE_URL;

const showColorMap: Record<string, string> = {
  BSG: "#dc2626",
  DNS: "#d97706",
  IJB: "#7c3aed",
  MM: "#0891b2",
};

const accentColor = showColorMap[host.shows[0]] ?? "#dc2626";

const initials = host.name
  .split(" ")
  .map((n: string) => n[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();

const hostShows = shows.filter((s) => host.shows.includes(s.shortName));
---

<Layout
  title={`${host.name} — Think BIG Bodybuilding`}
  description={host.bio}
>
  <!-- ─── HERO ─────────────────────────────────────── -->
  <section class="host-hero" style={`--accent:${accentColor};`}>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-content">
      <!-- Initials avatar -->
      <div
        class="host-avatar"
        style={`background: linear-gradient(135deg, ${accentColor}44, #141414); border-color:${accentColor}66;`}
      >
        {initials}
      </div>

      <!-- Name + role -->
      <div class="host-meta">
        <h1 class="host-name">{host.name}</h1>
        <p class="host-role" style={`color:${accentColor};`}>{host.role}</p>

        <!-- Show pills -->
        <div class="show-pills">
          {
            host.shows.map((s: string) => (
              <span
                class="show-pill"
                style={`color:${showColorMap[s] ?? "#888"}; border-color:${showColorMap[s] ?? "#333"}40; background:${showColorMap[s] ?? "#333"}12;`}
              >
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BODY ──────────────────────────────────────── -->
  <section class="body-section">
    <div class="body-inner">
      <!-- Left: bio + specialty -->
      <div class="bio-col">
        <p class="extended-bio">{host.extendedBio}</p>

        <div class="specialty-block">
          <h2 class="specialty-heading" style={`color:${accentColor};`}>
            Areas of Focus
          </h2>
          <ul class="specialty-list">
            {
              host.specialty.map((item: string) => (
                <li class="specialty-item" style={`--accent:${accentColor};`}>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Right: listen section -->
      <div class="listen-col">
        <h2 class="listen-heading">Listen to {host.name.split(" ")[0]}</h2>
        <div class="show-cards">
          {
            hostShows.map((show) => (
              <a
                href={`${base}${show.slug}`}
                class="show-link-card"
                style={`--show-accent:${show.color};`}
              >
                <span
                  class="show-color-stripe"
                  style={`background:${show.color};`}
                />
                <div class="show-link-body">
                  <span class="show-link-name">{show.name}</span>
                  <span class="show-link-tag">{show.tagline}</span>
                </div>
                <span class="show-link-arrow">→</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BACK LINK ────────────────────────────────── -->
  <div class="back-wrap">
    <a href={`${base}#hosts`} class="back-link">
      <span aria-hidden="true">←</span> Back to All Voices
    </a>
  </div>
</Layout>

<style>
  /* ─── Hero ──────────────────────────────────────── */
  .host-hero {
    position: relative;
    background: #0a0a0a;
    border-bottom: 1px solid #1a1a1a;
    overflow: hidden;
    padding: 5rem 1.5rem 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 55vh;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 65% 65% at 50% 0%,
      color-mix(in srgb, var(--accent) 18%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
    max-width: 48rem;
    width: 100%;
  }

  @media (min-width: 640px) {
    .hero-content {
      flex-direction: row;
      text-align: left;
      align-items: center;
    }
  }

  .host-avatar {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 2px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
  }

  @media (min-width: 640px) {
    .host-avatar {
      width: 140px;
      height: 140px;
      font-size: 3rem;
    }
  }

  .host-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  .host-name {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0;
  }

  .host-role {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin: 0;
  }

  .show-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .show-pills {
      justify-content: flex-start;
    }
  }

  .show-pill {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    padding: 0.3rem 0.75rem;
    border: 1px solid;
    border-radius: 2px;
  }

  /* ─── Body ──────────────────────────────────────── */
  .body-section {
    padding: 4rem 1.5rem;
    border-bottom: 1px solid #1a1a1a;
  }

  .body-inner {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 900px) {
    .body-inner {
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
      align-items: start;
    }
  }

  /* Bio column */
  .bio-col {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .extended-bio {
    font-size: 1rem;
    line-height: 1.8;
    color: #aaa;
    margin: 0;
  }

  .specialty-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .specialty-heading {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin: 0;
  }

  .specialty-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .specialty-item {
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
    color: #ccc;
    line-height: 1.55;
  }

  .specialty-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* Listen column */
  .listen-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .listen-heading {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #555;
    margin: 0;
  }

  .show-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .show-link-card {
    display: flex;
    align-items: center;
    gap: 0;
    background: #111;
    border: 1px solid #1f1f1f;
    border-radius: 4px;
    text-decoration: none;
    overflow: hidden;
    transition: border-color 150ms, transform 150ms;
  }

  .show-link-card:hover {
    border-color: var(--show-accent);
    transform: translateX(3px);
  }

  .show-color-stripe {
    display: block;
    width: 4px;
    align-self: stretch;
    flex-shrink: 0;
  }

  .show-link-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    padding: 1rem 1.1rem;
    min-width: 0;
  }

  .show-link-name {
    font-size: 0.9rem;
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
  }

  .show-link-tag {
    font-size: 0.72rem;
    color: #666;
    line-height: 1.3;
  }

  .show-link-arrow {
    padding: 0 1.1rem;
    color: #444;
    font-size: 0.9rem;
    transition: color 150ms;
    flex-shrink: 0;
  }

  .show-link-card:hover .show-link-arrow {
    color: var(--show-accent);
  }

  /* ─── Back link ──────────────────────────────────── */
  .back-wrap {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #555;
    text-decoration: none;
    transition: color 150ms;
  }

  .back-link:hover {
    color: #fff;
  }
</style>
