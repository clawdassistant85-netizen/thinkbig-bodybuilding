---
import Layout from "../layouts/Layout.astro";
import ShowCard from "../components/ShowCard.astro";
import YouTubeEmbed from "../components/YouTubeEmbed.astro";
import SponsorBar from "../components/SponsorBar.astro";
import HostCard from "../components/HostCard.astro";
import { shows } from "../data/shows.js";
import { hosts } from "../data/hosts.js";
import { social } from "../data/social.js";

const title = "Think BIG Bodybuilding Media — The Podcast Network That Goes There";
const description =
  "Four hardcore bodybuilding podcasts. 1,000+ episodes. IFBB Pros, elite coaches, and PhD scientists. Blood Sweat & Gear, Drugs N Stuff, It's Just Bodybuilding, and Muscle Minds.";

const hostAccent = {
  BSG: "#dc2626",
  DNS: "#d97706",
  IJB: "#7c3aed",
  MM: "#0891b2",
};

function accentFor(showCodes) {
  if (!showCodes || !showCodes.length) return "#dc2626";
  return hostAccent[showCodes[0]] ?? "#dc2626";
}
---

<Layout title={title} description={description}>
  <!-- HERO -->
  <section class="relative overflow-hidden tb-hero-glow">
    <div
      class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 md:pt-28 md:pb-32"
    >
      <div class="max-w-4xl">
        <span class="tb-label text-[#dc2626]">Since 2014 · 1,000+ episodes</span>
        <h1
          class="mt-5 text-4xl sm:text-5xl md:text-7xl font-black tracking-tight leading-[1.02] text-white"
        >
          The Bodybuilding Podcast Network That
          <span class="text-[#dc2626]">Goes There.</span>
        </h1>
        <p
          class="mt-6 text-base md:text-xl text-neutral-400 max-w-2xl leading-relaxed"
        >
          Four hardcore shows. One network. Over a thousand combined episodes
          from IFBB Pros, elite prep coaches, and a PhD exercise physiologist —
          answering real listener questions about training, nutrition, PEDs,
          and the business of building a championship physique.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href={social.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-3 rounded bg-[#dc2626] text-white text-sm font-bold uppercase tracking-widest hover:bg-[#b91c1c] transition-colors"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              ><path
                d="M23.498 6.186a2.99 2.99 0 0 0-2.107-2.117C19.455 3.55 12 3.55 12 3.55s-7.455 0-9.391.519A2.99 2.99 0 0 0 .502 6.186C0 8.132 0 12 0 12s0 3.868.502 5.814a2.99 2.99 0 0 0 2.107 2.117c1.936.519 9.391.519 9.391.519s7.455 0 9.391-.519a2.99 2.99 0 0 0 2.107-2.117C24 15.868 24 12 24 12s0-3.868-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"
              ></path></svg
            >
            Watch on YouTube
          </a>
          <a
            href={social.spotify}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-3 rounded bg-transparent border border-[#333] text-white text-sm font-bold uppercase tracking-widest hover:border-[#1DB954] hover:text-[#1DB954] transition-colors"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              ><path
                d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
              ></path></svg
            >
            Listen on Spotify
          </a>
        </div>

        <!-- Inline show chips -->
        <div class="mt-10 flex flex-wrap gap-2">
          {
            shows.map((show) => (
              <a
                href={`/${show.slug}`}
                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border text-xs font-semibold text-neutral-300 hover:text-white transition-colors"
                style={`border-color:${show.color}55; background:${show.color}11;`}
              >
                <span
                  class="w-1.5 h-1.5 rounded-full"
                  style={`background:${show.color};`}
                />
                {show.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- THE SHOWS -->
  <section class="relative py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10 gap-4 flex-wrap">
        <div>
          <span class="tb-label text-[#dc2626]">The Network</span>
          <h2
            class="mt-2 text-3xl md:text-5xl font-black tracking-tight text-white"
          >
            Four Shows. One Network.
          </h2>
          <p class="mt-3 text-neutral-400 max-w-2xl">
            Each show has its own voice, hosts, and focus — but they all share
            one standard: real answers from people who've actually been there.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {shows.map((show) => <ShowCard show={show} />)}
      </div>
    </div>
  </section>

  <!-- FEATURED VIDEO -->
  <section class="relative py-20 md:py-24 bg-[#0c0c0c] border-y border-[#222]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div>
          <span class="tb-label text-[#d97706]">Watch</span>
          <h2
            class="mt-2 text-3xl md:text-5xl font-black tracking-tight text-white"
          >
            Latest From The Network
          </h2>
        </div>
        <a
          href={social.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-[#dc2626] hover:text-white transition-colors"
        >
          Full Channel
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
        </a>
      </div>
      <div class="max-w-5xl mx-auto">
        <YouTubeEmbed videoId="pjBYVpp0U7E" title="Drugs N Stuff — Featured Episode" />
      </div>
    </div>
  </section>

  <!-- BY THE NUMBERS -->
  <section class="relative py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {
          [
            { value: "4", label: "Shows" },
            { value: "1,000+", label: "Episodes" },
            { value: "Top 1%", label: "Podcasts" },
            { value: "700+", label: "★ Reviews" },
          ].map((stat) => (
            <div class="tb-card rounded-lg p-6 text-center">
              <div class="text-3xl md:text-5xl font-black text-white tracking-tight">
                {stat.value}
              </div>
              <div class="tb-label mt-2 text-[#dc2626]">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- THE HOSTS -->
  <section class="relative py-20 md:py-24 bg-[#0c0c0c] border-y border-[#222]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <span class="tb-label text-[#dc2626]">The Roster</span>
        <h2
          class="mt-2 text-3xl md:text-5xl font-black tracking-tight text-white"
        >
          Meet The Voices
        </h2>
        <p class="mt-3 text-neutral-400 max-w-2xl">
          IFBB Pros, veteran prep coaches, a PhD exercise physiologist, and a
          harm-reduction specialist. Real experience, real credentials, real
          talk.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          hosts.map((h) => (
            <HostCard
              name={h.name}
              role={h.role}
              shows={h.shows}
              bio={h.bio}
              accent={accentFor(h.shows)}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- SPONSORS -->
  <SponsorBar />

  <!-- LISTEN EVERYWHERE -->
  <section class="relative py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <span class="tb-label text-[#dc2626]">Listen Everywhere</span>
        <h2
          class="mt-2 text-3xl md:text-5xl font-black tracking-tight text-white"
        >
          Pick Your Platform.
        </h2>
        <p class="mt-3 text-neutral-400">
          Every show is available on every major platform. New episodes weekly.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {
          [
            { name: "Spotify", url: social.spotify, color: "#1DB954" },
            { name: "Apple Podcasts", url: social.apple, color: "#a66cff" },
            { name: "YouTube", url: social.youtube, color: "#dc2626" },
            { name: "SoundCloud", url: social.soundcloud, color: "#ff7700" },
          ].map((p) => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="tb-card group rounded-lg p-6 flex flex-col items-center justify-center gap-2 text-center"
              style={`--accent:${p.color};`}
            >
              <span
                class="text-lg font-bold text-white group-hover:text-[var(--accent)] transition-colors"
                style={`--accent:${p.color};`}
              >
                {p.name}
              </span>
              <span class="text-xs text-neutral-500 uppercase tracking-widest">
                Listen Now →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
