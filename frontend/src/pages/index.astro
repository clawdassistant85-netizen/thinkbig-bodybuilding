---
import Layout from "../layouts/Layout.astro";
import SponsorBar from "../components/SponsorBar.astro";
import HostCard from "../components/HostCard.astro";
import YouTubeEmbed from "../components/YouTubeEmbed.astro";
import { shows } from "../data/shows.js";
import { hosts } from "../data/hosts.js";
import { social } from "../data/social.js";

const base = import.meta.env.BASE_URL;

const title = "Think BIG Bodybuilding Media — The Podcast Network That Goes There";
const description =
  "Four hardcore bodybuilding podcasts. 1,000+ episodes. IFBB Pros, elite coaches, and PhD scientists. Blood Sweat & Gear, Drugs N Stuff, It's Just Bodybuilding, and Muscle Minds.";

const hostAccent = {
  BSG: "#dc2626",
  DNS: "#d97706",
  IJB: "#7c3aed",
  MM: "#0891b2",
};
function accentFor(showCodes) {
  if (!showCodes?.length) return "#dc2626";
  return hostAccent[showCodes[0]] ?? "#dc2626";
}
---

<Layout title={title} description={description}>

  <!-- ─── HERO ──────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg-num" aria-hidden="true">1K+</div>

    <div class="hero-inner">
      <!-- Left: copy -->
      <div class="hero-copy">
        <div class="hero-eyebrow">
          <span class="eyebrow-dot"></span>
          Since 2014 &nbsp;·&nbsp; 4 Shows &nbsp;·&nbsp; 1,000+ Episodes
        </div>
        <h1 class="hero-h1">
          The Bodybuilding<br />Podcast Network<br />
          <span class="hero-red">That Goes There.</span>
        </h1>
        <p class="hero-sub">
          IFBB Pros, elite prep coaches, and a PhD exercise physiologist —
          answering real listener questions on training, nutrition, PEDs,
          and building a championship physique.
        </p>
        <div class="hero-ctas">
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="cta-primary">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a2.99 2.99 0 0 0-2.107-2.117C19.455 3.55 12 3.55 12 3.55s-7.455 0-9.391.519A2.99 2.99 0 0 0 .502 6.186C0 8.132 0 12 0 12s0 3.868.502 5.814a2.99 2.99 0 0 0 2.107 2.117c1.936.519 9.391.519 9.391.519s7.455 0 9.391-.519a2.99 2.99 0 0 0 2.107-2.117C24 15.868 24 12 24 12s0-3.868-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"/></svg>
            Watch on YouTube
          </a>
          <a href={social.spotify} target="_blank" rel="noopener noreferrer" class="cta-secondary">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            Listen on Spotify
          </a>
        </div>
      </div>

      <!-- Right: featured video -->
      <div class="hero-video">
        <div class="hero-video-label">
          <span class="video-eyebrow">Latest From The Network</span>
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="video-channel-link">
            Full Channel →
          </a>
        </div>
        <YouTubeEmbed videoId="ybu_KL-4srQ" title="Latest Episode — Drugs N Stuff" />
      </div>
    </div>

    <!-- Stats strip -->
    <div class="hero-stats">
      {[
        { value: "4", label: "Shows" },
        { value: "1,000+", label: "Episodes" },
        { value: "Top 1%", label: "Podcasts" },
        { value: "700+", label: "★ Reviews" },
      ].map((s) => (
        <div class="stat-cell">
          <span class="stat-val">{s.value}</span>
          <span class="stat-lbl">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── THE SHOWS ─────────────────────────────────────── -->
  <section class="shows-section" id="shows">
    <div class="section-wrap">
      <div class="section-header">
        <div>
          <span class="eyebrow-label">The Network</span>
          <h2 class="section-h2">Four Shows. One Network.</h2>
        </div>
        <p class="section-sub">
          Each show has its own voice, hosts, and focus — all sharing one standard:
          real answers from people who've actually been there.
        </p>
      </div>
    </div>

    <div class="shows-grid">
      {shows.map((show) => (
        <div class="show-feat" style={`--c:${show.color};`}>

          {/* Video thumbnail */}
          <div class="show-vid-wrap">
            <div class="show-yt-facade" data-id={show.sampleVideoId} data-title={show.name}>
              <img
                src={`https://i.ytimg.com/vi/${show.sampleVideoId}/hqdefault.jpg`}
                alt={`${show.name} — latest episode`}
                loading="lazy"
                class="show-yt-thumb"
              />
              <button class="show-yt-play" aria-label={`Play ${show.name}`}>
                <svg width="56" height="40" viewBox="0 0 68 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79 0 34 0 34 0S12.21 0 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C0 13.05 0 24 0 24s0 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 48 34 48 34 48s21.79 0 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C68 34.95 68 24 68 24s0-10.95-1.48-16.26z" fill="#FF0000"/>
                  <path d="M45 24 27 14v20l18-10z" fill="white"/>
                </svg>
              </button>
            </div>
            <span class="show-eps-tag">{show.episodeCount} eps</span>
          </div>

          {/* Show info */}
          <div class="show-body">
            <div class="show-body-top">
              <h3 class="show-feat-name">{show.name}</h3>
              <p class="show-feat-tagline">{show.tagline}</p>
            </div>

            <p class="show-feat-desc">{show.description}</p>

            <div class="show-feat-topics">
              {show.topics.slice(0, 4).map((t) => (
                <span class="show-feat-topic">{t}</span>
              ))}
            </div>

            <div class="show-feat-foot">
              <p class="show-feat-hosts">{show.hosts.join(' · ')}</p>
              <div class="show-feat-actions">
                <a href={show.spotifyUrl} target="_blank" rel="noopener noreferrer"
                   class="show-icon-btn" title="Listen on Spotify">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                </a>
                <a href={show.appleUrl} target="_blank" rel="noopener noreferrer"
                   class="show-icon-btn" title="Apple Podcasts">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2.182c5.415 0 9.818 4.403 9.818 9.818S17.415 21.818 12 21.818 2.182 17.415 2.182 12 6.585 2.182 12 2.182zm0 2.545c-4.017 0-7.273 3.256-7.273 7.273S7.983 19.273 12 19.273s7.273-3.256 7.273-7.273S16.017 4.727 12 4.727zm0 1.637c3.108 0 5.636 2.528 5.636 5.636S15.108 17.636 12 17.636 6.364 15.108 6.364 12 8.892 6.364 12 6.364zm0 2.727c-.602 0-1.09.489-1.09 1.09v4.365c0 .602.488 1.09 1.09 1.09s1.09-.488 1.09-1.09v-4.364c0-.602-.488-1.091-1.09-1.091zm0-2.182c-.752 0-1.364.612-1.364 1.364S11.248 9.818 12 9.818s1.364-.612 1.364-1.364S12.752 6.909 12 6.909z"/></svg>
                </a>
                <a href={`${base}${show.slug}`} class="show-cta-btn">
                  Full Show
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <script>
      document.querySelectorAll('.show-yt-facade').forEach((facade) => {
        const el = facade as HTMLElement;
        el.querySelector('.show-yt-play')?.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = el.dataset.id;
          const iframe = document.createElement('iframe');
          iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
          iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
          iframe.setAttribute('allowfullscreen', '');
          iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
          el.replaceWith(iframe);
        }, { once: true });
      });
    </script>
  </section>

  <!-- ─── HOSTS ─────────────────────────────────────────── -->
  <section class="hosts-section" id="hosts">
    <div class="section-wrap">
      <span class="eyebrow-label">The Roster</span>
      <h2 class="section-h2">Meet The Voices</h2>
      <p class="section-sub" style="margin-bottom:2.5rem;">
        IFBB Pros, veteran prep coaches, a PhD exercise physiologist, and a
        harm-reduction specialist. Real experience. Real credentials. Real talk.
        Click any voice to learn more.
      </p>
      <div class="hosts-grid">
        {hosts.map((h) => (
          <HostCard
            id={h.id}
            name={h.name}
            role={h.role}
            shows={h.shows}
            bio={h.bio}
            accent={accentFor(h.shows)}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SPONSORS ──────────────────────────────────────── -->
  <SponsorBar />

  <!-- ─── COMMUNITY CTA ──────────────────────────────────── -->
  <section class="community-section">
    <div class="section-wrap">
      <div class="community-grid">
        <a href={social.patreon} target="_blank" rel="noopener noreferrer" class="community-card community-patreon">
          <div class="community-card-inner">
            <span class="community-eyebrow">Support The Network</span>
            <h3 class="community-title">Join The Patreon</h3>
            <p class="community-sub">Exclusive episodes, direct Q&amp;A with the hosts, and early access. The show exists because of Patreon members.</p>
            <span class="community-cta">Become a Patron →</span>
          </div>
        </a>
        <a href={social.facebook} target="_blank" rel="noopener noreferrer" class="community-card community-facebook">
          <div class="community-card-inner">
            <span class="community-eyebrow">Join The Conversation</span>
            <h3 class="community-title">Facebook Community</h3>
            <p class="community-sub">Thousands of serious lifters, coaches, and competitors. Ask questions, share progress, and dig into the details between episodes.</p>
            <span class="community-cta">Join The Group →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── LISTEN EVERYWHERE ────────────────────────────── -->
  <section class="listen-section">
    <div class="section-wrap">
      <div class="listen-center">
        <span class="eyebrow-label">Listen Everywhere</span>
        <h2 class="section-h2">Pick Your Platform.</h2>
        <p class="section-sub">Every show. Every platform. New episodes weekly.</p>
      </div>
      <div class="platforms-grid">
        {[
          { name: "Spotify", url: social.spotify, color: "#1DB954", icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>` },
          { name: "Apple Podcasts", url: social.apple, color: "#a66cff", icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2.182c5.415 0 9.818 4.403 9.818 9.818S17.415 21.818 12 21.818 2.182 17.415 2.182 12 6.585 2.182 12 2.182zm0 2.545c-4.017 0-7.273 3.256-7.273 7.273S7.983 19.273 12 19.273s7.273-3.256 7.273-7.273S16.017 4.727 12 4.727zm0 1.637c3.108 0 5.636 2.528 5.636 5.636S15.108 17.636 12 17.636 6.364 15.108 6.364 12 8.892 6.364 12 6.364zm0 2.727c-.602 0-1.09.489-1.09 1.09v4.365c0 .602.488 1.09 1.09 1.09s1.09-.488 1.09-1.09v-4.364c0-.602-.488-1.091-1.09-1.091zm0-2.182c-.752 0-1.364.612-1.364 1.364S11.248 9.818 12 9.818s1.364-.612 1.364-1.364S12.752 6.909 12 6.909z"/></svg>` },
          { name: "YouTube", url: social.youtube, color: "#dc2626", icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a2.99 2.99 0 0 0-2.107-2.117C19.455 3.55 12 3.55 12 3.55s-7.455 0-9.391.519A2.99 2.99 0 0 0 .502 6.186C0 8.132 0 12 0 12s0 3.868.502 5.814a2.99 2.99 0 0 0 2.107 2.117c1.936.519 9.391.519 9.391.519s7.455 0 9.391-.519a2.99 2.99 0 0 0 2.107-2.117C24 15.868 24 12 24 12s0-3.868-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"/></svg>` },
          { name: "SoundCloud", url: social.soundcloud, color: "#ff7700", icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M11.56 8.87V17h8.76c1.56-.01 2.68-1.29 2.68-2.56 0-1.29-1.04-2.32-2.38-2.45.24-.49.38-1.02.38-1.58 0-2.04-1.65-3.69-3.7-3.69-1.06 0-2.02.44-2.71 1.15-.35-.56-.95-.93-1.7-.93-.98 0-1.53.73-1.53 1.73v1.23zm-1.63 8.13H2.18C1.08 17 0 15.96 0 14.87c0-1.09.83-2.12 2.12-2.29C2.08 12.27 2 11.94 2 11.6c0-1.52 1.27-2.75 2.85-2.75.71 0 1.36.26 1.85.69.36-.42.9-.69 1.5-.69.92 0 1.65.61 1.82 1.42.22-.06.45-.09.68-.09 1.53 0 2.76 1.23 2.76 2.76 0 .39-.08.76-.23 1.1.78.21 1.35.93 1.35 1.79 0 1.02-.82 1.84-1.84 1.84-.07 0-.13-.01-.18-.01z"/></svg>` },
        ].map((p) => (
          <a href={p.url} target="_blank" rel="noopener noreferrer"
            class="platform-card" style={`--accent:${p.color};`}>
            <span class="platform-icon" style={`color:${p.color};`} set:html={p.icon} />
            <span class="platform-name">{p.name}</span>
            <span class="platform-cta">Listen Now →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Shared helpers ─────────────────────────────────── */
  .section-wrap {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .eyebrow-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #dc2626;
    margin-bottom: 0.5rem;
  }
  .section-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin: 0 0 0.75rem;
  }
  .section-sub {
    color: #555;
    font-size: 0.9rem;
    line-height: 1.65;
    max-width: 48rem;
    margin: 0;
  }

  /* ── HERO ───────────────────────────────────────────── */
  .hero {
    position: relative;
    background:
      radial-gradient(ellipse 60% 70% at 0% -5%, rgba(220,38,38,0.2), transparent),
      radial-gradient(ellipse 40% 50% at 100% 80%, rgba(217,119,6,0.07), transparent),
      #090909;
    overflow: hidden;
    border-bottom: 1px solid #1a1a1a;
  }
  .hero-bg-num {
    position: absolute;
    right: -2rem;
    top: 5%;
    font-size: clamp(10rem, 28vw, 26rem);
    font-weight: 900;
    color: rgba(255,255,255,0.02);
    letter-spacing: -0.05em;
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero-bg-num { display: none; }
  }

  .hero-copy { min-width: 0; }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #444;
    margin-bottom: 1.5rem;
  }
  .eyebrow-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #dc2626;
    box-shadow: 0 0 8px #dc2626;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 4px #dc2626; opacity: 1; }
    50% { box-shadow: 0 0 14px #dc2626, 0 0 22px #dc262655; opacity: 0.75; }
  }
  .hero-h1 {
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0 0 1.25rem;
  }
  .hero-red { color: #dc2626; }
  .hero-sub {
    font-size: 0.92rem;
    color: #5a5a5a;
    line-height: 1.7;
    margin: 0 0 1.75rem;
    max-width: 36rem;
  }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .cta-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: #dc2626; color: #fff;
    font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.14em;
    border-radius: 3px; text-decoration: none;
    transition: background 150ms;
  }
  .cta-primary:hover { background: #b91c1c; }
  .cta-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: transparent; color: #888;
    font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.14em;
    border: 1px solid #2a2a2a; border-radius: 3px;
    text-decoration: none; transition: color 150ms, border-color 150ms;
  }
  .cta-secondary:hover { color: #1DB954; border-color: #1DB954; }

  .hero-video { min-width: 0; }
  .hero-video-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .video-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #d97706;
  }
  .video-channel-link {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #444;
    text-decoration: none;
    transition: color 150ms;
  }
  .video-channel-link:hover { color: #dc2626; }

  /* Stats strip */
  .hero-stats {
    position: relative; z-index: 1;
    display: flex;
    border-top: 1px solid #1a1a1a;
  }
  .stat-cell {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 1.25rem 0.5rem;
    border-right: 1px solid #1a1a1a;
