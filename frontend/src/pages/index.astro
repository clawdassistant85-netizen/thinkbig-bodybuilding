---
import Layout from "../layouts/Layout.astro";
import ShowCard from "../components/ShowCard.astro";
import SponsorBar from "../components/SponsorBar.astro";
import HostCard from "../components/HostCard.astro";
import YouTubeEmbed from "../components/YouTubeEmbed.astro";
import { shows } from "../data/shows.js";
import { hosts } from "../data/hosts.js";
import { social } from "../data/social.js";

const base = import.meta.env.BASE_URL;

const title = "Think BIG Bodybuilding Media — The Podcast Network That Goes There";
const description =
  "Four hardcore bodybuilding podcasts. 1,000+ episodes. IFBB Pros, elite coaches, and PhD scientists. Blood Sweat & Gear, Drugs N Stuff, It's Just Bodybuilding, and Muscle Minds.";

const hostAccent = {
  BSG: "#dc2626",
  DNS: "#d97706",
  IJB: "#7c3aed",
  MM: "#0891b2",
};
function accentFor(showCodes) {
  if (!showCodes?.length) return "#dc2626";
  return hostAccent[showCodes[0]] ?? "#dc2626";
}
---

<Layout title={title} description={description}>

  <!-- ─── HERO ──────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg-num" aria-hidden="true">1K+</div>

    <div class="hero-inner">
      <!-- Left: copy -->
      <div class="hero-copy">
        <div class="hero-eyebrow">
          <span class="eyebrow-dot"></span>
          Since 2014 &nbsp;·&nbsp; 4 Shows &nbsp;·&nbsp; 1,000+ Episodes
        </div>
        <h1 class="hero-h1">
          The Bodybuilding<br />Podcast Network<br />
          <span class="hero-red">That Goes There.</span>
        </h1>
        <p class="hero-sub">
          IFBB Pros, elite prep coaches, and a PhD exercise physiologist —
          answering real listener questions on training, nutrition, PEDs,
          and building a championship physique.
        </p>
        <div class="hero-ctas">
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="cta-primary">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a2.99 2.99 0 0 0-2.107-2.117C19.455 3.55 12 3.55 12 3.55s-7.455 0-9.391.519A2.99 2.99 0 0 0 .502 6.186C0 8.132 0 12 0 12s0 3.868.502 5.814a2.99 2.99 0 0 0 2.107 2.117c1.936.519 9.391.519 9.391.519s7.455 0 9.391-.519a2.99 2.99 0 0 0 2.107-2.117C24 15.868 24 12 24 12s0-3.868-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"/></svg>
            Watch on YouTube
          </a>
          <a href={social.spotify} target="_blank" rel="noopener noreferrer" class="cta-secondary">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            Listen on Spotify
          </a>
        </div>
      </div>

      <!-- Right: featured video -->
      <div class="hero-video">
        <div class="hero-video-label">
          <span class="video-eyebrow">Latest From The Network</span>
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="video-channel-link">
            Full Channel →
          </a>
        </div>
        <YouTubeEmbed videoId="pjBYVpp0U7E" title="Latest Episode — Drugs N Stuff" />
      </div>
    </div>

    <!-- Stats strip -->
    <div class="hero-stats">
      {[
        { value: "4", label: "Shows" },
        { value: "1,000+", label: "Episodes" },
        { value: "Top 1%", label: "Podcasts" },
        { value: "700+", label: "★ Reviews" },
      ].map((s) => (
        <div class="stat-cell">
          <span class="stat-val">{s.value}</span>
          <span class="stat-lbl">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── THE SHOWS ─────────────────────────────────────── -->
  <section class="shows-section" id="shows">
    <div class="section-wrap">
      <div class="section-header">
        <div>
          <span class="eyebrow-label">The Network</span>
          <h2 class="section-h2">Four Shows. One Network.</h2>
        </div>
        <p class="section-sub">
          Each show has its own voice, hosts, and focus — all sharing one standard:
          real answers from people who've actually been there.
        </p>
      </div>
    </div>
    <div class="shows-list">
      {shows.map((show, i) => <ShowCard show={show} index={i} />)}
    </div>
  </section>

  <!-- ─── HOSTS ─────────────────────────────────────────── -->
  <section class="hosts-section" id="hosts">
    <div class="section-wrap">
      <span class="eyebrow-label">The Roster</span>
      <h2 class="section-h2">Meet The Voices</h2>
      <p class="section-sub" style="margin-bottom:2.5rem;">
        IFBB Pros, veteran prep coaches, a PhD exercise physiologist, and a
        harm-reduction specialist. Real experience. Real credentials. Real talk.
        Click any voice to learn more.
      </p>
      <div class="hosts-grid">
        {hosts.map((h) => (
          <HostCard
            id={h.id}
            name={h.name}
            role={h.role}
            shows={h.shows}
            bio={h.bio}
            accent={accentFor(h.shows)}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SPONSORS ──────────────────────────────────────── -->
  <SponsorBar />

  <!-- ─── LISTEN EVERYWHERE ────────────────────────────── -->
  <section class="listen-section">
    <div class="section-wrap">
      <div class="listen-center">
        <span class="eyebrow-label">Listen Everywhere</span>
        <h2 class="section-h2">Pick Your Platform.</h2>
        <p class="section-sub">Every show. Every platform. New episodes weekly.</p>
      </div>
      <div class="platforms-grid">
        {[
          { name: "Spotify", url: social.spotify, color: "#1DB954" },
          { name: "Apple Podcasts", url: social.apple, color: "#a66cff" },
          { name: "YouTube", url: social.youtube, color: "#dc2626" },
          { name: "SoundCloud", url: social.soundcloud, color: "#ff7700" },
        ].map((p) => (
          <a href={p.url} target="_blank" rel="noopener noreferrer"
            class="platform-card" style={`--accent:${p.color};`}>
            <span class="platform-name">{p.name}</span>
            <span class="platform-cta">Listen Now →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Shared helpers ─────────────────────────────────── */
  .section-wrap {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .eyebrow-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #dc2626;
    margin-bottom: 0.5rem;
  }
  .section-h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin: 0 0 0.75rem;
  }
  .section-sub {
    color: #555;
    font-size: 0.9rem;
    line-height: 1.65;
    max-width: 48rem;
    margin: 0;
  }

  /* ── HERO ───────────────────────────────────────────── */
  .hero {
    position: relative;
    background:
      radial-gradient(ellipse 60% 70% at 0% -5%, rgba(220,38,38,0.2), transparent),
      radial-gradient(ellipse 40% 50% at 100% 80%, rgba(217,119,6,0.07), transparent),
      #090909;
    overflow: hidden;
    border-bottom: 1px solid #1a1a1a;
  }
  .hero-bg-num {
    position: absolute;
    right: -2rem;
    top: 5%;
    font-size: clamp(10rem, 28vw, 26rem);
    font-weight: 900;
    color: rgba(255,255,255,0.02);
    letter-spacing: -0.05em;
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero-bg-num { display: none; }
  }

  .hero-copy { min-width: 0; }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #444;
    margin-bottom: 1.5rem;
  }
  .eyebrow-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #dc2626;
    box-shadow: 0 0 8px #dc2626;
    flex-shrink: 0;
  }
  .hero-h1 {
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0 0 1.25rem;
  }
  .hero-red { color: #dc2626; }
  .hero-sub {
    font-size: 0.92rem;
    color: #5a5a5a;
    line-height: 1.7;
    margin: 0 0 1.75rem;
    max-width: 36rem;
  }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .cta-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: #dc2626; color: #fff;
    font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.14em;
    border-radius: 3px; text-decoration: none;
    transition: background 150ms;
  }
  .cta-primary:hover { background: #b91c1c; }
  .cta-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: transparent; color: #888;
    font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.14em;
    border: 1px solid #2a2a2a; border-radius: 3px;
    text-decoration: none; transition: color 150ms, border-color 150ms;
  }
  .cta-secondary:hover { color: #1DB954; border-color: #1DB954; }

  .hero-video { min-width: 0; }
  .hero-video-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .video-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #d97706;
  }
  .video-channel-link {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #444;
    text-decoration: none;
    transition: color 150ms;
  }
  .video-channel-link:hover { color: #dc2626; }

  /* Stats strip */
  .hero-stats {
    position: relative; z-index: 1;
    display: flex;
    border-top: 1px solid #1a1a1a;
  }
  .stat-cell {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 1.25rem 0.5rem;
    border-right: 1px solid #1a1a1a;
  }
  .stat-cell:last-child { border-right: none; }
  .stat-val {
    font-size: clamp(1.3rem, 3vw, 2.2rem);
    font-weight: 900; color: #fff;
    letter-spacing: -0.03em; line-height: 1;
  }
  .stat-lbl {
    font-size: 0.58rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.2em;
    color: #dc2626; margin-top: 0.3rem;
  }

  /* ── SHOWS ──────────────────────────────────────────── */
  .shows-section { padding: 4.5rem 0 0; }
  .section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .shows-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
    margin-top: 0;
  }

  /* ── HOSTS ──────────────────────────────────────────── */
  .hosts-section {
    padding: 4.5rem 0;
    background: #0c0c0c;
    border-top: 1px solid #1a1a1a;
    margin-top: 4.5rem;
  }
  .hosts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* ── LISTEN ─────────────────────────────────────────── */
  .listen-section {
    padding: 4.5rem 0;
    border-top: 1px solid #1a1a1a;
  }
  .listen-center {
    text-align: center;
    max-width: 34rem;
    margin: 0 auto 2.5rem;
  }
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .platforms-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .platform-card {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 0.4rem;
    padding: 1.75rem 1rem;
    background: #111; border: 1px solid #1f1f1f;
    border-radius: 4px; text-decoration: none;
    transition: border-color 150ms, transform 150ms;
  }
  .platform-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .platform-name {
    font-size: 0.88rem; font-weight: 800; color: #fff;
    transition: color 150ms;
  }
  .platform-card:hover .platform-name { color: var(--accent); }
  .platform-cta {
    font-size: 0.6rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.15em; color: #333;
  }
</style>
